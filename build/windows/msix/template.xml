<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="AI-ViewNote.exe"
        Arguments=""
        InstallLocation="C:\Program Files\AI-ViewNote\AI-ViewNote">
    </Installer>
    <PackageInformation
        PackageName="AI-ViewNote"
        PackageDisplayName="AI-ViewNote"
        PublisherName="CN=AI-ViewNote"
        PublisherDisplayName="AI-ViewNote"
        Version="0.1.0.0"
        PackageDescription="AI powered video note taking application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.aiviewnote.aiviewnote"
                Description="AI powered video note taking application"
                DisplayName="AI-ViewNote"
                ExecutableName="AI-ViewNote.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>AI-ViewNote</DisplayName>
            <PublisherDisplayName>AI-ViewNote</PublisherDisplayName>
            <Description>AI powered video note taking application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="AI-ViewNote.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
